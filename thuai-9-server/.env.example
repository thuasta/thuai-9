# Copy this file to .env and fill in the values.
# NEVER commit .env to git.

# PostgreSQL password (generate with: openssl rand -hex 32)
POSTGRES_PASSWORD=

# JWT signing secret — REQUIRED, must be >= 16 chars or the API refuses to start
# (generate with: openssl rand -hex 32)
JWT_SECRET=

# Admin account password for the submission portal
ADMIN_PASSWORD=
