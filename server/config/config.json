{
  "server": {
    "port": 14514,
    "acceptAnyToken": true
  },
  "token": {
    "loadTokenFromEnv": true,
    "tokenLocation": "TOKENS",
    "tokenDelimiter": ","
  },
  "log": {
    "target": "Console",
    "minimumLevel": "Information",
    "targetDirectory": "./logs",
    "rollingInterval": "Day"
  },
  "game": {
    "ticksPerSecond": 10,
    "tradingDayTicks": 30,
    "tradingDayCount": 3,
    "infiniteMode": true,
    "strategySelectionTicks": 40,
    "minimumPlayerCount": 2,
    "playerWaitingTicks": 200,
    "disconnectedPlayerRetentionTicks": 0,
    "initialMora": 1000000,
    "initialGold": 1000,
    "initialGoldPrice": 1000,
    "defaultNetworkDelay": 1,
    "defaultFeeRate": 0.0002,
    "maxOrdersPerTick": 2,
    "maxImmediateOrdersPerDay": 1,
    "maxRestingOrdersPerDay": 1,
    "maxReportsPerNews": 1,
    "newsIntervalMin": 200,
    "newsIntervalMax": 400,
    "researchWindowTicks": 2,
    "researchSettlementDelay": 3,
    "baseResearchReward": 10000,
    "npcOrdersPerTick": 3
  },
  "recorder": {
    "keepRecord": false,
    "flushEveryRecords": 1000,
    "statisticsSaveIntervalTicks": 100,
    "enableStatRecording": true,
    "statFlushEveryRecords": 500
  },
  "newsGeneration": {
    "enabled": true,
    "provider": "openai-compatible",
    "baseUrl": "http://localhost:8080/v1",
    "chatCompletionsPath": "/chat/completions",
    "apiKey": "",
    "apiKeyEnv": "THUAI_LLM_API_KEY",
    "model": "Qwopus3.6-27B-v2-Q4_K_M.gguf",
    "temperature": 0.9,
    "maxTokens": 256,
    "timeoutMs": 1500,
    "prewarmTimeoutMs": 20000,
    "chatTemplateEnableThinking": false,
    "maxContentLength": 80,
    "prewarmEnabled": true,
    "prewarmPerSentiment": 8,
    "prewarmConcurrency": 2,
    "refillThreshold": 2,
    "refillBatchSize": 4,
    "systemPrompt": "你是 THUAI-9 黄金交易比赛的“华清街快报”新闻编辑。你的任务是生成游戏内短新闻。\n每条新闻必须像街区传闻或市场花边，中文输出，语气可以夸张、诙谐，但只能提供间接线索。\n你会收到隐藏方向：偏紧表示街上金料更难周转；偏松表示街上金料更容易周转。\n正文只能写具体街区事件、人物动作或店铺异状，不要替玩家总结市场结论。\n不要提到 LLM、AI、提示词、JSON、sentiment、Bullish、Bearish、真假新闻或游戏机制。\n不要出现这些词或近义表达：利好、利空、看涨、看跌、上涨、下跌、飙升、暴跌、拉升、跳水、走强、走弱、承压、金价、价格、短线、买入、卖出。\n不要写央行、国际金价、历史新高、避险情绪、现货市场、产量、库存、供应这类现实财经套话。\n不要给投资建议，不要写编号，不要解释原因，只生成一条 18 到 42 个中文字符的新闻正文。\n必须只返回 JSON 对象：{\"content\":\"新闻正文\"}。"
  }
}
